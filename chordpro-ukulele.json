// ChordPro config for Queen of Saba songbook
// Ukulele, standard tuning G4-C4-E4-A4
// Courier New, 2 columns, one song per page

{
  "include": [ "ukulele" ],

  "chords": [
    // Italian chord aliases (same fingerings as English equivalents)
    { "name": "DO",    "base": 1, "frets": [ 0, 0, 0, 3 ], "easy": true },
    { "name": "DO7",   "base": 1, "frets": [ 0, 0, 0, 1 ], "easy": true },
    { "name": "RE-",   "base": 1, "frets": [ 2, 2, 1, 0 ], "easy": true },
    { "name": "MI-",   "base": 1, "frets": [ 0, 4, 0, 2 ], "easy": false },
    { "name": "MI7",   "base": 1, "frets": [ 1, 2, 0, 2 ], "easy": true },
    { "name": "FA",    "base": 1, "frets": [ 2, 0, 1, 0 ], "easy": true },
    { "name": "FA-",   "base": 1, "frets": [ 1, 0, 1, 3 ], "easy": false },
    { "name": "SOL",   "base": 1, "frets": [ 0, 2, 3, 2 ], "easy": true },
    { "name": "SOL7",     "base": 1, "frets": [ 0, 2, 1, 2 ], "easy": true },
    { "name": "SOL7sus2", "base": 1, "frets": [ 0, 2, 1, 0 ], "easy": true },
    { "name": "G7sus2",   "base": 1, "frets": [ 0, 2, 1, 0 ], "easy": true },
    { "name": "C/G",      "base": 1, "frets": [ 0, 0, 0, 3 ], "easy": true },
    { "name": "DO/SOL7",  "base": 1, "frets": [ 0, 2, 1, 2 ], "easy": true },
    { "name": "SOL-7", "base": 1, "frets": [ 0, 2, 1, 1 ], "easy": true },
    { "name": "LA-",   "base": 1, "frets": [ 2, 0, 0, 0 ], "easy": true },
    { "name": "LA-7",  "base": 1, "frets": [ 0, 0, 0, 0 ], "easy": true },
    { "name": "Csus2",  "base": 1, "frets": [ 0, 2, 3, 3 ], "easy": false },
    { "name": "C#",     "base": 1, "frets": [ 1, 1, 1, 4 ], "easy": true },
    { "name": "C#m",    "base": 1, "frets": [ 1, 1, 0, 4 ], "easy": false },
    { "name": "A#",     "base": 1, "frets": [ 3, 2, 1, 1 ], "easy": true },
    { "name": "F#",     "base": 1, "frets": [ 3, 1, 2, 1 ], "easy": false },
    { "name": "F#m",    "base": 1, "frets": [ 2, 1, 2, 0 ], "easy": false },
    { "name": "Ab",     "base": 1, "frets": [ 5, 3, 4, 3 ], "easy": false },
    { "name": "Dsus4",  "base": 1, "frets": [ 0, 2, 3, 0 ], "easy": false },
    { "name": "Dsus2",  "base": 1, "frets": [ 2, 2, 0, 0 ], "easy": false },
    { "name": "Asus4",  "base": 1, "frets": [ 0, 0, 2, 3 ], "easy": false }
  ],

  "settings": {
    "columns": 2
  },

  "pdf": {
    "pagealign-songs": 0,
    "fonts": {
      "text":    { "file": "/usr/share/fonts/truetype/msttcorefonts/cour.ttf",   "size": 11 },
      "chord":   { "file": "/usr/share/fonts/truetype/msttcorefonts/cour.ttf", "size": 11, "color": "blue" },
      "title":   { "file": "/usr/share/fonts/truetype/msttcorefonts/courbd.ttf", "size": 12 },
      "comment": { "file": "/usr/share/fonts/truetype/msttcorefonts/couri.ttf",  "size": 9 }
    },
    "columnspace": 15,
    "headspace": 30,
    "margintop": 40,
    "spacing": {
      "title": 0.8,
      "chords": 1.0
    }
  },

  "diagrams": {
    "show": "all",
    "sorted": true,
    "suppress": [ "DO/SOL7", "C/G", "D/F#", "Bm/F#", "G/B", "F/E", "F/Eb",
      "Dm7/C", "Bb/F", "A#/D", "D6/9", "Em9", "Dmaj9",
      "Am/B", "Am/C", "Am/D", "C/E", "D/A", "G/F#", "Am/E",
      "Gsus", "Dsus", "Cm6", "F/C", "A#m" ]
  }
}
